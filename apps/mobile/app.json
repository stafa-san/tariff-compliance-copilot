{
  "expo": {
    "name": "Tariff Copilot",
    "slug": "tariff-copilot",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "tariffcopilot",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tariffcopilot.app",
      "buildNumber": "1",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSCameraUsageDescription": "Used to scan documents and invoices for compliance analysis",
        "NSPhotoLibraryUsageDescription": "Used to upload documents and invoices for compliance analysis"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F172A"
      },
      "package": "com.tariffcopilot.app",
      "versionCode": 1
    },
    "plugins": [
      "expo-font",
      "expo-updates",
      "expo-document-picker"
    ],
    "extra": {
      "eas": {
        "projectId": "7436baf4-6fc5-4f11-be5a-fb0ac01e9aff"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/7436baf4-6fc5-4f11-be5a-fb0ac01e9aff"
    },
    "runtimeVersion": "1.0.0"
  }
}
